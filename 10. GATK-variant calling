#!/usr/bin/env bash
set -euo pipefail

#########################################
# PATHS
#########################################

BAM_DIR="/rhome/poulamis/shared/labprojects/WGS-Liberibacter-Pol/bam"
REF_DIR="/rhome/poulamis/shared/labprojects/WGS-Liberibacter-Pol/Reference/ncbi_dataset/data/GCF_000183665.1"
REF_FASTA="${REF_DIR}/GCF_000183665.1_ASM18366v1_genomic.fna"
OUT_DIR="${BAM_DIR}/variants"

#########################################
# PREP
#########################################

mkdir -p "$OUT_DIR"

echo "✅ Checking tools..."
for tool in bcftools samtools; do
    if ! command -v $tool &>/dev/null; then
        echo "❌ ERROR: $tool not found"
        exit 1
    fi
done
echo "✅ Tools OK"

#########################################
# COLLECT BAM FILES
#########################################

BAM_LIST=("$BAM_DIR"/*.markdup.bam)

if [ ${#BAM_LIST[@]} -eq 0 ]; then
    echo "❌ No BAM files found"
    exit 1
fi

echo "✅ Found ${#BAM_LIST[@]} BAM files"

#########################################
# VARIANT CALLING (HAPLOID BACTERIA)
#########################################

echo "🚀 Calling SNPs (haploid)..."

bcftools mpileup \
    -f "$REF_FASTA" \
    -q 20 -Q 20 -d 400 \
    -Ou \
    "${BAM_LIST[@]}" | \
bcftools call \
    -mv \
    --ploidy 1 \
    -Oz \
    -o "$OUT_DIR/raw_snps.vcf.gz"

#########################################
# FILTERING
#########################################

echo "🚀 Filtering SNPs (QUAL>=30, DP>=10)..."

bcftools filter \
    -e 'QUAL<30 || DP<10' \
    -Oz \
    -o "$OUT_DIR/filtered_snps.vcf.gz" \
    "$OUT_DIR/raw_snps.vcf.gz"

#########################################
# INDEX
#########################################

echo "📌 Indexing VCFs..."

bcftools index "$OUT_DIR/raw_snps.vcf.gz"
bcftools index "$OUT_DIR/filtered_snps.vcf.gz"

echo "🎉 SNP calling finished successfully!"
echo "📁 Output directory: $OUT_DIR"


